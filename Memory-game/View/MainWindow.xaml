<Window x:Class="Memory_game.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Memory_game"
        xmlns:vm ="clr-namespace:Memory_game.ViewModel"
        mc:Ignorable="d"
        Title="Gra Memory" Height="500" Width="316"
        d:DataContext="{d:DesignInstance Type=vm:ServerListWindowViewModel}">

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="0.5*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition Height=".2*"/>
                <RowDefinition Height=".3*"/>
                <RowDefinition Height=".3*"/>
                <RowDefinition Height=".3*"/>
            </Grid.RowDefinitions>

            <Label Content="Menu" HorizontalAlignment="Center" VerticalAlignment="Center" Width="50" FontWeight="Bold" FontSize="14"/>
            <Button Content="Stwórz nowe&#xD;&#xA;    Lobby" HorizontalAlignment="Center" VerticalAlignment="Center" Height="42" Width="112"
                    Grid.Row="1"
                    Command="{Binding OpenBoardCommand}"/>
            <Button Content="       Dołącz do &#xA;istniejącego Lobby" HorizontalAlignment="Center" VerticalAlignment="Center" Height="42" Width="112"
                    Grid.Row="2"
                    Command="{Binding OpenServerList}"/>
            <Button Content="Wybierz talię kart" HorizontalAlignment="Center" VerticalAlignment="Center" Height="42" Width="112"
                    Grid.Row="3"
                    Command="{Binding OpenCardDeckWindowCommand}"/>
            
        </Grid>
        <Grid Grid.Row="1">

            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="1" Content="Send message" Height="50" Width="100" Command="{Binding SendMessageToSever}"/>
        </Grid>

    </Grid>


</Window>
