<Window x:Class="Memory_game.View.BoardSetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Memory_game.View"
        xmlns:vm="clr-namespace:Memory_game.ViewModel"
        mc:Ignorable="d"
        Title="Ustawienia planszy" Height="350" Width="400"
        WindowStartupLocation="CenterOwner"
        d:DataContext="{d:DesignInstance Type=vm:BoardSetupViewModel}">

    <Grid Margin="20,20,20,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Label Content="Nazwa lobby:" Grid.Column="0" VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" Text="{Binding LobbyName, UpdateSourceTrigger=PropertyChanged}" Margin="10,5"/>
        </Grid>

        <Label Content="Ustawienia planszy" Grid.Row="1" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,10,0,10"/>

        <Grid Grid.Row="2" Margin="0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Label Content="Liczba wierszy:" Grid.Column="0" VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" Text="{Binding Rows, UpdateSourceTrigger=PropertyChanged}" Margin="10,5"/>
        </Grid>

        <Grid Grid.Row="3" Margin="0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Label Content="Liczba kolumn:" Grid.Column="0" VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" Text="{Binding Columns, UpdateSourceTrigger=PropertyChanged}" Margin="10,5"/>
        </Grid>

        <Grid Grid.Row="4" Margin="0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Label Content="Czas na ruch (sekundy):" Grid.Column="0" VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" Text="{Binding TurnTime, UpdateSourceTrigger=PropertyChanged}" Margin="10,5"/>
        </Grid>

        <TextBlock Grid.Row="5" Text="{Binding ErrorMessage}" Foreground="Red" HorizontalAlignment="Center" Margin="0,10" Width="360" TextAlignment="Center" TextWrapping="Wrap"/>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,10">
            <Button Content="Cofnij" Width="80" Height="30" Margin="5" Command="{Binding CancelCommand}"/>
            <Button Content="Start" Width="80" Height="30" Margin="5" Background="LightGreen"
                     Command="{Binding StartCommand}"
                    IsEnabled="{Binding CanInteract}"/>
        </StackPanel>
    </Grid>
</Window>