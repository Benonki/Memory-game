<Window x:Class="Memory_game.View.BoardSetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Memory_game.View"
        xmlns:vm="clr-namespace:Memory_game.ViewModel"
        mc:Ignorable="d"
        Title="Ustawienia planszy" Height="232" Width="400"
        WindowStartupLocation="CenterOwner"
        d:DataContext="{d:DesignInstance Type=vm:BoardSetupViewModel}">

    <Grid Margin="20,20,20,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="79.24"/>
            <RowDefinition Height="172.8"/>
        </Grid.RowDefinitions>

        <Label Content="Ustaw wymiary planszy" Grid.Row="0" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,48"/>

        <Grid Margin="0,46,0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Label Content="Liczba wierszy:" Grid.Column="0" VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" Text="{Binding Rows, UpdateSourceTrigger=PropertyChanged}" Margin="10,5"/>
        </Grid>

        <Grid Grid.Row="1" Margin="0,5,0,140">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Label Content="Liczba kolumn:" Grid.Column="0" VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" Text="{Binding Columns, UpdateSourceTrigger=PropertyChanged}" Margin="10,5"/>
        </Grid>

        <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" HorizontalAlignment="Center" Margin="0,27,0,37" Width="360" TextAlignment="Center"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="93,0,0,95" Grid.Row="1">
            <Button Content="Cofnij" Width="80" Height="30" Margin="5" Command="{Binding CancelCommand}"/>
            <Button Content="Start" Width="80" Height="30" Margin="5" Command="{Binding StartCommand}" Background="LightGreen"/>
        </StackPanel>
    </Grid>
</Window>