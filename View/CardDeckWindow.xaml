<Window x:Class="Memory_game.View.CardDeckWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Memory_game.View"
        xmlns:vm="clr-namespace:Memory_game.ViewModel"
        mc:Ignorable="d"
        Title="Talie kart" Height="400" Width="400"
        WindowStartupLocation="CenterOwner"
        d:DataContext="{d:DesignInstance Type=vm:CardDeckViewModel}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Label Content="Zarządzaj taliami" Grid.Row="0" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>

        <Grid Grid.Row="1" Margin="0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Label Content="Nowa talia:" Grid.Column="0" VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" Text="{Binding NewDeckName, UpdateSourceTrigger=PropertyChanged}" Margin="10,5"/>
            <Button Grid.Column="2" Content="Utwórz" Width="70" Height="30" Command="{Binding CreateDeckCommand}"/>
        </Grid>

        <Grid Grid.Row="2" Margin="0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Label Content="Wybrana talia:" Grid.Column="0" VerticalAlignment="Center"/>
            <ComboBox Grid.Column="1" ItemsSource="{Binding AvailableDecks}" SelectedItem="{Binding SelectedDeck}" Margin="10,5"/>
        </Grid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,5">
            <Button Content="Dodaj karty" Width="100" Height="30" Margin="5" Command="{Binding AddCardsCommand}"/>
            <Button Content="Usuń talię" Width="100" Height="30" Margin="5" Command="{Binding DeleteDeckCommand}"/>
            <Button Content="Przejrzyj karty" Width="100" Height="30" Margin="5" Command="{Binding SeeCardDeckPreviewCommand}"/>
        </StackPanel>

        <TextBlock Grid.Row="4" Text="{Binding ErrorMessage}" Foreground="red" HorizontalAlignment="Center" Margin="0,5" TextAlignment="Center" TextWrapping="Wrap"/>

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Zamknij" Width="80" Height="30" Margin="5" Command="{Binding CancelCommand}"/>
        </StackPanel>
    </Grid>
</Window>